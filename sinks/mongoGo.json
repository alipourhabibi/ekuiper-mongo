{
  "about": {
    "trial": true,
    "author": {
      "name": "Ali Pourhabibi",
      "email": "ali.Pourhabibi1379@gmail.com",
      "company": "RahkarSanat",
      "website": "https://rahkarsanat.ir"
    },
    "helpUrl": {
      "en_US": "https://github.com/alipourhabibi/ekuiper-mongo/blob/master/README.md"
    },
    "description": {
      "en_US": "This a sink plugin for mongodb, it can be used for saving the analysis data into monogodb."
    }
  },
  "libs": [],
  "properties": [
    {
      "name": "interval",
      "default": 1000,
      "optional": true,
      "control": "text",
      "type": "int",
      "hint": {
        "en_US": "the interval which you want to send data to mongodb."
      },
      "label": {
        "en_US": "Interval of sending data"
      }
    },
    {
      "name": "conString",
      "default": "mongodb://localhost:27017/",
      "optional": true,
      "control": "text",
      "type": "string",
      "hint": {
        "en_US": "The Connection string for mongodb."
      },
      "label": {
        "en_US": "ConnectionString"
      }
    },
    {
      "name": "dbName",
      "default": "ekuiper",
      "optional": true,
      "control": "text",
      "type": "string",
      "hint": {
        "en_US": "Database Name to save data to."
      },
      "label": {
        "en_US": "DatabaseName"
      }
    },
    {
      "name": "colName",
      "default": "ekuiper",
      "optional": true,
      "control": "text",
      "type": "string",
      "hint": {
        "en_US": "Collection Name to save data to."
      },
      "label": {
        "en_US": "CollectionName"
      }
    },
    {
      "name": "maxPoolSize",
      "default": 16,
      "optional": true,
      "control": "text",
      "type": "int",
      "hint": {
        "en_US": "Maximum number of connections in the MongoDB connection pool."
      },
      "label": {
        "en_US": "Max Pool Size"
      }
    },
    {
      "name": "connectTimeoutMs",
      "default": 5000,
      "optional": true,
      "control": "text",
      "type": "int",
      "hint": {
        "en_US": "Timeout in milliseconds for establishing a new MongoDB connection."
      },
      "label": {
        "en_US": "Connect Timeout (ms)"
      }
    },
    {
      "name": "serverSelTimeoutMs",
      "default": 30000,
      "optional": true,
      "control": "text",
      "type": "int",
      "hint": {
        "en_US": "Timeout in milliseconds for selecting a MongoDB server."
      },
      "label": {
        "en_US": "Server Selection Timeout (ms)"
      }
    },
    {
      "name": "maxBufferSize",
      "default": 0,
      "optional": true,
      "control": "text",
      "type": "int",
      "hint": {
        "en_US": "Maximum number of items to buffer before applying backpressure. 0 means unlimited."
      },
      "label": {
        "en_US": "Max Buffer Size"
      }
    },
    {
      "name": "onBufferFull",
      "default": "drop",
      "optional": true,
      "control": "select",
      "type": "string",
      "values": ["drop", "block"],
      "hint": {
        "en_US": "Behaviour when buffer is full: 'drop' silently discards the item; 'block' returns an error so eKuiper applies backpressure."
      },
      "label": {
        "en_US": "On Buffer Full"
      }
    },
    {
      "name": "maxRetries",
      "default": 3,
      "optional": true,
      "control": "text",
      "type": "int",
      "hint": {
        "en_US": "Number of times to retry a failed InsertMany before giving up."
      },
      "label": {
        "en_US": "Max Retries"
      }
    }
  ]
}
